# ── PlatformIO build output ──────────────────────────────────────────────────
.pio/

# ── WiFi credentials — NEVER commit ─────────────────────────────────────────
src/wifi_creds.h

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# ── ESP-IDF generated files (auto-regenerated on build) ─────────────────────
sdkconfig
sdkconfig.xiao_esp32s3
sdkconfig.seeed_xiao_esp32s3

# ── IDF Component Manager (fetched at build time, not part of source) ────────
managed_components/
dependencies.lock

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# ── Gateway log data and trained models (generated at runtime, not source) ───
mic_tools/logs/
mic_tools/model/

# ── Backup and temp files ─────────────────────────────────────────────────────
*.bak
*.orig
*.swp
*.tmp
